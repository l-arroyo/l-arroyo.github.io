@page "/not-found"
@using Portfolio.Components.Generic
@layout MainLayout

<section id="not-found">

    <h3>Not Found</h3>
    <p>Sorry, the content you are looking for does not exist.</p>

    <AppButton Text="Home" OnClick="@GoHome" />

</section>

@code {

    [Inject]
    public NavigationManager NavigationManager { get; set; } = default!;

    #region Parameters

    [CascadingParameter]
    public MainLayout Layout { get; set; } = default!;

    #endregion

    protected override void OnInitialized()
    {
        Layout.SetFixedLayout(true);
        Layout.SetInnerPadding(false);
    }

    private void GoHome()
    {
        NavigationManager.NavigateTo("/");
    }
}