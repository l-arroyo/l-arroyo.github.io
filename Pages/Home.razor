@code {

    [Inject]
    public NavigationManager NavigationManager { get; set; } = default!;

    [Inject]
    public IJSRuntime JSRuntime { get; set; } = default!;

    #region Variables

    private readonly List<string> _images =
    [
        "/img/SongSpotter-1.jpg",
            "/img/SongSpotter-2.jpg",
            "/img/SongSpotter-3.jpg"
    ];

    #endregion

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
            return;

        CleanUrl();
    }

    private void CleanUrl()
    {
        var uri = new Uri(NavigationManager.Uri);

        if (!string.IsNullOrEmpty(uri.Fragment))
        {
            NavigationManager.NavigateTo(uri.GetLeftPart(UriPartial.Path), replace: true);
        }
    }

    private async Task SetSection(string section)
    {
        await JSRuntime.InvokeVoidAsync("scrollToSection", section);

        StateHasChanged();
    }

}